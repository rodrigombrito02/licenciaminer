# ══════════════════════════════════════════════════════════════════
# Variaveis de ambiente — copie para .env (gitignored) e ajuste
# ══════════════════════════════════════════════════════════════════

# ── Dados ──
# Diretorio base de dados (padrao: ./data)
# Em producao Railway com volume, use o mount path do volume:
# DATA_DIR=/app/data
# DATA_DIR=./data

# Caminho do banco DuckDB (padrao: ./data/licenciaminer.duckdb)
# DB_PATH=./data/licenciaminer.duckdb

# ── CORS (BACKEND — defina no Railway) ──
# Lista de URLs autorizadas a chamar a API, separadas por virgula.
# As URLs padrao (summo-quartile.vercel.app + licenciaminer-production.up.railway.app)
# ja estao no codigo. Adicione aqui o subdominio customizado caso use.
# CORS_ORIGINS=https://summoquartile.vercel.app,https://app.summoquartile.com

# ── Frontend (FRONTEND — defina no Vercel) ──
# URL completa da API (incluindo /api no final).
# Exemplo apos deploy do backend Railway:
# NEXT_PUBLIC_API_URL=https://summoquartile-api.up.railway.app/api

# ── Anthropic API (modulo Chat — opcional) ──
# ANTHROPIC_API_KEY=sk-ant-...

# ── URLs das fontes publicas (so sobrescrever se endpoints mudarem) ──
# IBAMA_SISLIC_URL=https://dadosabertos.ibama.gov.br/dados/SISLIC/sislic-licencas.json
# ANM_FEATURESERVER_URL=https://geo.anm.gov.br/arcgis/rest/services/SIGMINE/dados_anm/FeatureServer/0/query
